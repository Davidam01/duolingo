generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ExerciseType {
  TRANSLATION
  MULTIPLE_CHOICE
  FILL_BLANK
  LISTENING
  SPEAKING
}

enum AchievementType {
  STREAK
  XP_MILESTONE
  LESSONS_COMPLETED
  PERFECT_LESSON
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  hashedPassword String?
  xp            Int        @default(0)
  streak        Int        @default(0)
  lastActivity  DateTime?

  accounts    Account[]
  sessions    Session[]
  progress    Progress[]
  achievements UserAchievement[]
  leaderboards   Leaderboard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  language    String
  level       String
  image       String?
  order       Int      @default(0)

  sections Section[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("courses")
}

model Section {
  id       String @id @default(cuid())
  title    String
  order    Int    @default(0)
  courseId  String

  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  @@map("sections")
}

model Lesson {
  id        String @id @default(cuid())
  title     String
  order     Int    @default(0)
  sectionId String

  section   Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@map("lessons")
}

model Exercise {
  id          String       @id @default(cuid())
  type        ExerciseType
  question    String
  options     String?
  answer      String
  lessonId    String

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress    Progress[]

  @@map("exercises")
}

model Progress {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  correct    Boolean
  completed  Boolean  @default(false)

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@map("progress")
}

model Achievement {
  id          String          @id @default(cuid())
  type        AchievementType
  title       String
  description String?
  icon        String?
  threshold   Int

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Leaderboard {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime
  weekEnd   DateTime
  xp        Int      @default(0)
  rank      Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([weekStart, xp])
  @@map("leaderboard")
}
